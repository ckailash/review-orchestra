{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["findings", "metadata"],
  "properties": {
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "file",
          "line",
          "confidence",
          "impact",
          "severity",
          "category",
          "title",
          "description",
          "suggestion",
          "reviewer",
          "pre_existing"
        ],
        "properties": {
          "id": { "type": "string" },
          "file": { "type": "string" },
          "line": { "type": "integer" },
          "confidence": {
            "type": "string",
            "enum": ["verified", "likely", "possible", "speculative"]
          },
          "impact": {
            "type": "string",
            "enum": ["critical", "functional", "quality", "nitpick"]
          },
          "severity": {
            "type": "string",
            "enum": ["p0", "p1", "p2", "p3"]
          },
          "category": { "type": "string" },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "suggestion": { "type": "string" },
          "reviewer": { "type": "string" },
          "pre_existing": { "type": "boolean", "default": false },
          "status": {
            "type": "string",
            "enum": ["new", "persisting"]
          },
          "expected": { "type": "string" },
          "observed": { "type": "string" },
          "evidence": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "required": [],
      "properties": {
        "reviewer": { "type": "string" },
        "round": { "type": "integer" },
        "timestamp": { "type": "string", "format": "date-time" },
        "files_reviewed": { "type": "integer" },
        "diff_scope": { "type": "string" }
      }
    }
  }
}
