{
  "name": "review-orchestra",
  "version": "0.1.0",
  "description": "Multi-model automated code review orchestration for Claude Code",
  "type": "module",
  "main": "dist/orchestrator.js",
  "bin": {
    "review-orchestra": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "eval": "tsx evals/run-eval.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "code-review",
    "claude",
    "codex",
    "orchestration"
  ],
  "author": "Kailash Chandrasekaran <mail@ckailash.com>",
  "license": "MIT",
  "files": [
    "dist/",
    "config/",
    "prompts/",
    "schemas/",
    "skill/",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ckailash/review-orchestra.git"
  },
  "homepage": "https://github.com/ckailash/review-orchestra",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "tsup": "^8.5.1",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
